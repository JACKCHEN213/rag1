# RAG System Environment Configuration

# Application
DEBUG=False
HOST=0.0.0.0
PORT=8000
SECRET_KEY=your-secret-key-here

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Database - MySQL 8.0
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=rag_system

# Database - Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# Database - Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Embedding Model - BGE-M3
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=auto  # auto, cpu, cuda
EMBEDDING_BATCH_SIZE=32

# Reranker Model - BGE-Reranker
RERANKER_MODEL_NAME=BAAI/bge-reranker-large
RERANKER_DEVICE=auto
RERANKER_TOP_K=5

# LLM Configuration
LLM_PROVIDER=openai  # openai, claude, local
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_EXTENSIONS=[".pdf", ".docx", ".doc", ".xlsx", ".xls", ".pptx", ".md", ".txt", ".jpg", ".png"]

# Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_WORKERS=4

# Search
DEFAULT_TOP_K=10
SEARCH_DISTANCE_THRESHOLD=0.7

# Memory
SHORT_MEMORY_SIZE=10
LONG_MEMORY_IMPORTANCE_THRESHOLD=0.8
